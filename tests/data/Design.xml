<?xml version="1.0" encoding="UTF-8"?>
<d:design xmlns:d="http://cern.ch/quasar/Design"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          projectShortName="ScaDemo"
          xsi:schemaLocation="http://cern.ch/quasar/Design Design.xsd">
  <d:class name="SCA">
    <d:devicelogic/>
    <d:cachevariable name="online" dataType="OpcUa_UInt32" addressSpaceWrite="forbidden"
                     initializeWith="valueAndStatus" nullPolicy="nullAllowed"
                     initialStatus="OpcUa_BadWaitingForInitialData"/>
    <d:cachevariable name="id" dataType="UaString" addressSpaceWrite="forbidden"
                     initializeWith="configuration" nullPolicy="nullAllowed"/>
    <d:cachevariable name="temperature" dataType="OpcUa_Double" addressSpaceWrite="regular"
                     initializeWith="configuration" nullPolicy="nullAllowed"/>
    <d:cachevariable name="channels" dataType="OpcUa_UInt16" addressSpaceWrite="forbidden"
                     initializeWith="configuration" nullPolicy="nullForbidden">
      <d:array/>
    </d:cachevariable>
    <d:cachevariable name="target" dataType="OpcUa_Double" addressSpaceWrite="delegated"
                     initializeWith="configuration" nullPolicy="nullAllowed"/>
    <d:sourcevariable name="adc" dataType="OpcUa_Double" addressSpaceRead="synchronous"
                      addressSpaceWrite="forbidden" addressSpaceReadUseMutex="no"
                      addressSpaceWriteUseMutex="no"/>
    <d:sourcevariable name="dac" dataType="OpcUa_Double" addressSpaceRead="synchronous"
                      addressSpaceWrite="synchronous" addressSpaceReadUseMutex="no"
                      addressSpaceWriteUseMutex="no"/>
    <d:method name="reset"/>
    <d:method name="scale">
      <d:argument name="factor" dataType="OpcUa_Double"/>
      <d:returnvalue name="result" dataType="OpcUa_Double"/>
    </d:method>
    <d:hasobjects instantiateUsing="configuration" class="Chip"/>
  </d:class>
  <d:class name="Chip">
    <d:devicelogic/>
    <d:cachevariable name="bar" dataType="OpcUa_Double" addressSpaceWrite="forbidden"
                     initializeWith="valueAndStatus" nullPolicy="nullForbidden"
                     initialValue="3.14" initialStatus="OpcUa_Good"/>
  </d:class>
  <d:root>
    <d:hasobjects instantiateUsing="configuration" class="SCA"/>
  </d:root>
</d:design>
